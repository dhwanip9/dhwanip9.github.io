              <path d="M18 232 Q120 214 224 236 Q322 254 422 234"></path>
              <path
                d="M150 226 q10 -14 20 0 q10 -12 20 2 M250 240 q10 -14 20 0 q10 -12 20 2"
                stroke-width="1.6"></path>
              <path
                d="M34 234 L18 210 M40 234 L30 204 M46 234 L46 200 M52 234 L62 206 M58 234 L74 212"
                stroke-width="1.6"></path>
            </svg>

            <!-- 3 · Perth — Kings Park skyline -->
            <svg
              data-scene="2"
              data-illo
              viewBox="0 0 440 320"
              style="position:absolute;inset:0;width:100%;height:100%;opacity:0;transition:opacity .7s ease"
              fill="none"
              stroke="#2743E8"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="30" y1="256" x2="410" y2="256"></line>
              <rect x="118" y="150" width="30" height="106"></rect>
