                stroke-width="1.7"></path>
            </svg>

            <!-- 6 · SF Bay — Golden Gate Bridge -->
            <svg
              data-scene="5"
              data-illo
              viewBox="0 0 440 320"
              style="position:absolute;inset:0;width:100%;height:100%;opacity:0;transition:opacity .7s ease"
              fill="none"
              stroke="#2743E8"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="20" y1="214" x2="420" y2="188" stroke-width="2.2"></line>
              <line x1="20" y1="226" x2="420" y2="200" stroke-width="2.2"></line>
