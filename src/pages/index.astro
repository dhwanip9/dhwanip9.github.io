              <line x1="126" y1="170" x2="140" y2="170"></line>
              <line x1="126" y1="192" x2="140" y2="192"></line>
              <line x1="126" y1="214" x2="140" y2="214"></line>
              <line x1="164" y1="128" x2="182" y2="128"></line>
              <line x1="164" y1="156" x2="182" y2="156"></line>
              <line x1="164" y1="184" x2="182" y2="184"></line>
              <line x1="164" y1="212" x2="182" y2="212"></line>
              <line x1="206" y1="150" x2="218" y2="150"></line>
              <line x1="206" y1="178" x2="218" y2="178"></line>
              <line x1="206" y1="206" x2="218" y2="206"></line>
              <line x1="276" y1="160" x2="290" y2="160"></line>
              <line x1="276" y1="188" x2="290" y2="188"></line>
              <line x1="276" y1="216" x2="290" y2="216"></line>
              <path
                d="M46 256 L46 220 M56 256 L52 214 M66 256 L66 210 M76 256 L82 216 M86 256 L94 222"
