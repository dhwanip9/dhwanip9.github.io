              <path
                d="M40 110 l24 -6 M40 116 l16 0 M356 96 l24 -6 M356 102 l16 0"
                stroke-width="1.4"></path>
            </svg>

            <!-- 5 · Seattle — Space Needle + skyline + Rainier -->
            <svg
              data-scene="4"
              data-illo
              viewBox="0 0 440 320"
              style="position:absolute;inset:0;width:100%;height:100%;opacity:0;transition:opacity .7s ease"
              fill="none"
              stroke="#2743E8"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="106" y1="256" x2="94" y2="150"></line>
              <line x1="106" y1="256" x2="118" y2="150"></line>
              <line x1="99" y1="204" x2="113" y2="204"></line>
