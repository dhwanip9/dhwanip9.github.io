              <path d="M108 292 L108 214 Q121 190 134 214 L134 292"></path>
              <path d="M306 292 L306 214 Q319 190 332 214 L332 292"></path>
            </svg>

            <!-- 2 · Brisbane — Story Bridge -->
            <svg
              data-scene="1"
              data-illo
              viewBox="0 0 440 320"
              style="position:absolute;inset:0;width:100%;height:100%;opacity:0;transition:opacity .7s ease"
              fill="none"
              stroke="#2743E8"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="188" y="96" width="20" height="90"></rect>
              <rect x="214" y="74" width="22" height="112"></rect>
              <line x1="225" y1="74" x2="225" y2="58"></line>
