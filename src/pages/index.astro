<script>
  // ---------------------------------------------------------------------------
  // Reveal-on-scroll + city stepper + hero parallax.
  // Rewritten in vanilla JS from the original Claude Design DCLogic component.
  // ---------------------------------------------------------------------------
  const reveal = (el: HTMLElement) => {
    el.style.clipPath = 'inset(0 0 0 0)';
    el.style.opacity = '1';
    el.style.transform = 'none';
  };

  const reveals = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            reveal(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
    );
    reveals.forEach((el) => io.observe(el));

    // Reveal anything already in view on load (observer can miss initial paint).
    setTimeout(() => {
      reveals.forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) {
          reveal(el);
          io.unobserve(el);
        }
      });
    }, 400);
  } else {
    reveals.forEach(reveal);
  }

  // ---- city stepper ----
  const scenes = Array.from(document.querySelectorAll<HTMLElement>('[data-scene]'));
  const rail = Array.from(document.querySelectorAll<HTMLElement>('[data-idx]'));
  const steps = Array.from(document.querySelectorAll<HTMLElement>('[data-step]'));
  const BLUE = '#2743E8';
  let active = 0;

  const setActive = (i: number) => {
    if (i === active) return;
    active = i;
    scenes.forEach((s, k) => {
      s.style.opacity = k === i ? '1' : '0';
    });
    rail.forEach((el, k) => {
      el.style.color = k === i ? BLUE : '#B7B1A5';
      el.style.opacity = k === i ? '1' : '0.55';
      el.style.fontSize = k === i ? '17px' : '15px';
    });
  };

  if ('IntersectionObserver' in window && steps.length) {
    const stepIO = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            setActive(Number((e.target as HTMLElement).getAttribute('data-step')));
          }
        });
      },
      { rootMargin: '-45% 0px -45% 0px', threshold: 0 }
    );
    steps.forEach((s) => stepIO.observe(s));
  }

  rail.forEach((el) => {
    el.style.cursor = 'pointer';
    el.addEventListener('click', () => {
      const i = Number(el.getAttribute('data-idx'));
      const step = steps[i];
      if (step) {
        window.scrollTo({
          top: window.scrollY + step.getBoundingClientRect().top - window.innerHeight * 0.32,
          behavior: 'smooth',
        });
      }
    });
  });

  // ---- hero decor parallax ----
  const spark = document.getElementById('spark');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (spark && !prefersReduced) {
    window.addEventListener(
      'pointermove',
      (ev) => {
        const cx = ev.clientX / window.innerWidth - 0.5;
        const cy = ev.clientY / window.innerHeight - 0.5;
        spark.style.transform = `translate3d(${(cx * 40).toFixed(1)}px,${(cy * 34).toFixed(1)}px,0)`;
      },
      { passive: true }
    );
  }
</script>
