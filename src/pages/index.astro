              <path d="M92 292 L92 126 L150 126 L150 292"></path>
              <path d="M290 292 L290 126 L348 126 L348 292"></path>
              <path d="M92 126 Q121 100 150 126"></path>
              <path d="M290 126 Q319 100 348 126"></path>
