---
import Base from '../layouts/Base.astro';
---

<Base>
  <div id="page" style="position:relative;min-height:100vh;background:#E9E5DC">
    <!-- ══════════════ 1 · LANDING (cement) ══════════════ -->
    <section
      data-screen-label="Hero"
      style="position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:flex-start;justify-content:center;text-align:left;padding:80px clamp(28px,7vw,110px);box-sizing:border-box;overflow:hidden;background:#E9E5DC"
    >
      <div
        id="spark"
        style="position:absolute;right:16%;top:20%;pointer-events:none;animation:floatA 12s ease-in-out infinite"
      >
        <svg width="72" height="72" viewBox="0 0 100 100">
          <defs>
            <linearGradient id="spk" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#F4CBAA"></stop>
              <stop offset=".5" stop-color="#EFB4C1"></stop>
              <stop offset="1" stop-color="#BCC6EC"></stop>
            </linearGradient>
          </defs>
          <path
            d="M50 2 C54 34 66 46 98 50 C66 54 54 66 50 98 C46 66 34 54 2 50 C34 46 46 34 50 2Z"
            fill="url(#spk)"></path>
        </svg>
      </div>

      <div
        id="badge"
        style="position:absolute;right:9%;bottom:16%;width:132px;height:132px;pointer-events:none;animation:spin 26s linear infinite"
      >
        <svg viewBox="0 0 200 200" width="132" height="132">
          <defs>
            <path id="circ" d="M100,100 m-74,0 a74,74 0 1,1 148,0 a74,74 0 1,1 -148,0"></path>
          </defs>
          <text fill="#2743E8" font-family="Jost" font-size="13.5" letter-spacing="3.5" font-weight="500">
            <textPath href="#circ" startOffset="0">SCIENCE · STRATEGY · STORYTELLING · </textPath>
          </text>
          <circle cx="100" cy="100" r="6" fill="#2743E8"></circle>
        </svg>
      </div>

      <div style="position:relative;z-index:2;max-width:16ch">
        <div
          style="font-family:'Jost';font-size:12px;letter-spacing:.42em;text-transform:uppercase;color:#2743E8;font-weight:500;margin-bottom:26px"
        >
          Dhwani&nbsp;&nbsp;Patel
        </div>
        <h1
          style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(48px,8.4vw,124px);line-height:.98;letter-spacing:-.01em;margin:0;color:#2743E8"
        >
          bridging <span style="font-style:italic;font-weight:300">science,</span> strategy, and
          <span style="font-style:italic;font-weight:300">storytelling</span>
        </h1>
      </div>
      <p
        style="position:relative;z-index:2;font-family:'Jost';font-weight:300;font-size:clamp(15px,1.5vw,18px);color:#5B574E;max-width:520px;line-height:1.85;margin:30px 0 0"
      >
        A microbial-genomics PhD turned venture builder — carrying scientific rigor into operating
        clarity, by way of India, Australia, Canada, and the US.
      </p>
      <div
        style="position:relative;z-index:2;display:flex;gap:28px;margin-top:30px;font-family:'Jost';font-size:14px;letter-spacing:.02em"
      >
        <a href="https://www.linkedin.com/in/dhwaniapatel" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/dhwanip9" target="_blank" rel="noopener">GitHub</a>
        <a href="https://medium.com/@dhwanip9" target="_blank" rel="noopener">Medium</a>
      </div>

      <div
        style="position:absolute;left:0;right:0;bottom:0;height:130px;background:linear-gradient(90deg,#C9CF9F,#E7E0A2,#F3EACB,#F4CBAA,#EFB4C1,#BCC6EC);-webkit-mask:linear-gradient(180deg,transparent,#000 78%);mask:linear-gradient(180deg,transparent,#000 78%)"
      >
      </div>
      <div
        class="scroll-cue"
        style="position:absolute;bottom:26px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:9px;animation:drift 2.8s ease-in-out infinite"
      >
        <span
          style="font-family:'Jost';font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:#3A3830"
          >scroll</span
        >
        <svg width="16" height="26" viewBox="0 0 16 26" fill="none">
          <path
            d="M8 1v22M2 17l6 6 6-6"
            stroke="#3A3830"
            stroke-width="1.3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </section>

    <!-- ══════════════ 2 · ABOUT ME (cement) ══════════════ -->
    <section data-screen-label="About" style="position:relative;background:#E9E5DC;padding:120px 0 90px">
      <div
        class="about-grid"
        style="max-width:1000px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:300px 1fr;gap:64px;align-items:center"
      >
        <div
          data-reveal="left"
          style="opacity:0;transform:translateY(24px);clip-path:inset(0 100% 0 0);transition:clip-path 1s cubic-bezier(.22,1,.36,1),opacity .9s ease,transform 1s cubic-bezier(.22,1,.36,1);position:relative"
        >
          <div
            style="width:280px;height:340px;border-radius:0;overflow:hidden;box-shadow:0 16px 40px rgba(40,40,60,.16);position:relative;background:linear-gradient(150deg,#BCC6EC 0%,#EFB4C1 55%,#F4CBAA 100%);display:flex;align-items:flex-end;justify-content:flex-start"
          >
            <span
              style="font-family:'Jost';font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:rgba(35,33,28,.5);padding:14px 16px"
              >portrait</span
            >
          </div>
          <div
            style="position:absolute;left:-18px;bottom:-18px;width:70px;height:70px;background:linear-gradient(135deg,#EFB4C1,#BCC6EC);z-index:-0"
          >
          </div>
        </div>
        <div>
          <div
            data-reveal="right"
            style="opacity:0;clip-path:inset(0 0 0 100%);transition:clip-path 1s cubic-bezier(.22,1,.36,1),opacity .9s ease;display:inline-block;font-family:'Jost';font-size:12px;letter-spacing:.32em;text-transform:uppercase;color:#2743E8;font-weight:500;margin-bottom:18px"
          >
            About me
          </div>
          <h2
            data-reveal="right"
            style="opacity:0;clip-path:inset(0 0 0 100%);transition:clip-path 1.05s cubic-bezier(.22,1,.36,1) .06s,opacity .95s ease .06s;font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(34px,4.6vw,56px);line-height:1.05;letter-spacing:-.01em;margin:0 0 22px;color:#2743E8"
          >
            I never picked a single lane —<br />
            <span style="font-style:italic;font-weight:300">so I built the bridge between them.</span>
          </h2>
          <p
            data-reveal="right"
            style="opacity:0;clip-path:inset(0 0 0 100%);transition:clip-path 1.1s cubic-bezier(.22,1,.36,1) .12s,opacity 1s ease .12s;font-family:'Jost';font-weight:300;font-size:17px;line-height:1.85;color:#5B574E;margin:0 0 16px;max-width:52ch"
          >
            I trained as a scientist — sequencing microbial genomes and helping labs scale COVID-19
            testing across Canada — then crossed into venture-land, where I spent four years building
            the operating machinery behind a deeptech program.
          </p>
          <p
            data-reveal="right"
            style="opacity:0;clip-path:inset(0 0 0 100%);transition:clip-path 1.15s cubic-bezier(.22,1,.36,1) .18s,opacity 1.05s ease .18s;font-family:'Jost';font-weight:300;font-size:17px;line-height:1.85;color:#5B574E;margin:0;max-width:52ch"
          >
            Today I bring scientific credibility to operating problems, and operating discipline to
            scientific ones. Currently in San Jose, California.
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════ 3 · CITIES PANEL (sticky stepper, cement-2) ══════════════ -->
    <section data-screen-label="Journey" style="position:relative;background:#E2DDD1;padding:96px 0 60px">
      <div style="text-align:center;max-width:760px;margin:0 auto 40px;padding:0 32px">
        <div
          data-reveal="up"
          style="opacity:0;transform:translateY(20px);transition:opacity .9s ease,transform .9s cubic-bezier(.22,1,.36,1);font-family:'Jost';font-size:12px;letter-spacing:.32em;text-transform:uppercase;color:#2743E8;font-weight:500;margin-bottom:16px"
        >
          The winding path
        </div>
        <h2
          data-reveal="up"
          style="opacity:0;transform:translateY(20px);transition:opacity .95s ease .06s,transform .95s cubic-bezier(.22,1,.36,1) .06s;font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(34px,4.8vw,60px);line-height:1.02;margin:0;color:#2743E8"
        >
          Six cities, <span style="font-style:italic;font-weight:300">one continuous line</span>
        </h2>
        <p
          data-reveal="up"
          style="opacity:0;transform:translateY(20px);transition:opacity 1s ease .12s,transform 1s cubic-bezier(.22,1,.36,1) .12s;font-family:'Jost';font-weight:300;font-size:16px;color:#5B574E;margin:14px 0 0"
        >
          Not a ladder — a scenic route across four countries. Scroll through, or tap a number.
        </p>
      </div>

      <div
        class="journey-grid"
        style="max-width:1160px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start"
      >
        <!-- STICKY STAGE -->
        <div
          class="journey-stage"
          style="position:sticky;top:9vh;height:82vh;display:flex;flex-direction:column;justify-content:center"
        >
          <div style="display:flex;gap:14px;margin-bottom:26px">
            <span
              data-idx="0"
              style="font-family:'Jost';font-weight:500;font-size:17px;color:#2743E8;transition:color .35s,opacity .35s,font-size .35s"
              >01</span
            >
            <span
              data-idx="1"
              style="font-family:'Jost';font-weight:500;font-size:15px;color:#B7B1A5;opacity:.6;transition:color .35s,opacity .35s,font-size .35s"
              >02</span
            >
            <span
              data-idx="2"
              style="font-family:'Jost';font-weight:500;font-size:15px;color:#B7B1A5;opacity:.6;transition:color .35s,opacity .35s,font-size .35s"
              >03</span
            >
            <span
              data-idx="3"
              style="font-family:'Jost';font-weight:500;font-size:15px;color:#B7B1A5;opacity:.6;transition:color .35s,opacity .35s,font-size .35s"
              >04</span
            >
            <span
              data-idx="4"
              style="font-family:'Jost';font-weight:500;font-size:15px;color:#B7B1A5;opacity:.6;transition:color .35s,opacity .35s,font-size .35s"
              >05</span
            >
            <span
              data-idx="5"
              style="font-family:'Jost';font-weight:500;font-size:15px;color:#B7B1A5;opacity:.6;transition:color .35s,opacity .35s,font-size .35s"
              >06</span
            >
          </div>
          <div style="position:relative;width:100%;aspect-ratio:11/8;max-height:60vh">
            <div
              style="position:absolute;inset:6% 10%;border-radius:50%;background:radial-gradient(circle at 40% 35%,rgba(188,198,236,.7),rgba(239,180,193,.4) 55%,transparent 78%);filter:blur(8px)"
            >
            </div>

            <!-- 1 · Mumbai — Gateway of India -->
            <svg
              data-scene="0"
              data-illo
              viewBox="0 0 440 320"
              style="position:absolute;inset:0;width:100%;height:100%;opacity:1;transition:opacity .7s ease"
              fill="none"
              stroke="#2743E8"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
