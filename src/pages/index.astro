---
import Base from '../layouts/Base.astro';
---

<Base>
  <div id="page" style="position:relative;min-height:100vh;background:#E9E5DC">
    <!-- ══════════════ STICKY TOP NAV ══════════════ -->
    <nav
      style="position:sticky;top:0;z-index:50;display:flex;align-items:center;justify-content:space-between;gap:24px;padding:0 clamp(20px,4vw,54px);height:72px;background:rgba(233,229,220,.82);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(39,67,232,.14)"
    >
      <a
        href="#top"
        style="font-family:'Jost';font-size:13px;letter-spacing:.34em;text-transform:uppercase;color:#2743E8;font-weight:500;border-bottom:none"
        >Dhwani Patel</a
      >
      <div style="display:flex;align-items:center;gap:clamp(14px,2vw,30px);font-family:'Jost';font-size:14px">
        <a href="#about" class="nav-collapse" style="color:#3A3830;border-bottom:none">About</a>
        <a href="#background" class="nav-collapse" style="color:#3A3830;border-bottom:none">Background</a>
        <a href="#toolkit" class="nav-collapse" style="color:#3A3830;border-bottom:none">What I bring</a>
        <a href="#work" class="nav-collapse" style="color:#3A3830;border-bottom:none">Past work</a>
        <span class="nav-collapse" style="width:1px;height:20px;background:rgba(39,67,232,.22)"></span>
        <a
          href="https://www.linkedin.com/in/dhwaniapatel"
          target="_blank"
          rel="noopener"
          class="nav-collapse"
          style="color:#5B574E;border-bottom:none">LinkedIn</a
        >
        <a
          href="https://github.com/dhwanip9"
          target="_blank"
          rel="noopener"
          class="nav-collapse"
          style="color:#5B574E;border-bottom:none">GitHub</a
        >
        <a
          href="https://medium.com/@dhwanip9"
          target="_blank"
          rel="noopener"
          class="nav-collapse"
          style="color:#5B574E;border-bottom:none">Medium</a
        >
        <a
          href="/Dhwani-Patel-Resume.pdf"
          download
          class="nav-collapse hover-outline"
          style="display:inline-flex;align-items:center;gap:7px;font-size:13.5px;color:#2743E8;border:1px solid rgba(39,67,232,.5);border-radius:0;padding:8px 15px"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#2743E8" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v13M6 11l6 6 6-6M4 21h16"></path></svg>Résumé
        </a>
        <a
          href="#contact"
          class="hover-primary"
          style="font-size:13.5px;background:#2743E8;color:#F4F2EC;border:none;border-radius:0;padding:9px 18px">Contact</a
        >
      </div>
    </nav>

    <!-- ══════════════ 1 · HERO (cement) ══════════════ -->
    <section
      id="top"
      data-screen-label="Hero"
      style="position:relative;min-height:calc(100vh - 72px);display:flex;flex-direction:column;align-items:flex-start;justify-content:center;text-align:left;padding:70px clamp(28px,7vw,110px);box-sizing:border-box;overflow:hidden;background:#E9E5DC"
    >
      <div
        id="spark"
        style="position:absolute;right:16%;top:18%;pointer-events:none;animation:floatA 12s ease-in-out infinite"
      >
        <svg width="72" height="72" viewBox="0 0 100 100">
          <defs>
            <linearGradient id="spk" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#F4CBAA"></stop>
              <stop offset=".5" stop-color="#EFB4C1"></stop>
              <stop offset="1" stop-color="#BCC6EC"></stop>
            </linearGradient>
          </defs>
          <path
            d="M50 2 C54 34 66 46 98 50 C66 54 54 66 50 98 C46 66 34 54 2 50 C34 46 46 34 50 2Z"
            fill="url(#spk)"></path>
        </svg>
      </div>

      <div
        id="badge"
        style="position:absolute;right:9%;bottom:18%;width:132px;height:132px;pointer-events:none;animation:spin 26s linear infinite"
      >
        <svg viewBox="0 0 200 200" width="132" height="132">
          <defs>
            <path id="circ" d="M100,100 m-74,0 a74,74 0 1,1 148,0 a74,74 0 1,1 -148,0"></path>
          </defs>
          <text fill="#2743E8" font-family="Jost" font-size="13.5" letter-spacing="3.5" font-weight="500">
            <textPath href="#circ" startOffset="0">SCIENCE · STRATEGY · STORYTELLING · </textPath>
          </text>
          <circle cx="100" cy="100" r="6" fill="#2743E8"></circle>
        </svg>
      </div>

      <div style="position:relative;z-index:2;max-width:16ch">
        <div
          style="font-family:'Jost';font-size:16px;letter-spacing:.42em;text-transform:uppercase;color:#2743E8;font-weight:500;margin-bottom:26px"
        >
          Dhwani&nbsp;&nbsp;Patel
        </div>
      </div>
      <h1
        style="position:relative;z-index:2;font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(48px,8.4vw,124px);line-height:.98;letter-spacing:-.01em;margin:0;color:#2743E8"
      >
        bridging <span style="font-weight:300">deep-tech &amp;</span> strategy, to&nbsp;<span
          style="font-style:italic;font-weight:300">impact</span
        >
      </h1>
      <p
        style="position:relative;z-index:2;font-family:'Jost';font-weight:400;font-size:20px;color:#3A3830;max-width:657px;line-height:1.55;margin:30px 0 0"
      >
        A microbial-genomics PhD turned venture builder — carrying scientific rigor into operating
        clarity, by way of India, Australia, Canada, and the US.
      </p>

      <div style="position:relative;z-index:2;display:flex;flex-wrap:wrap;gap:16px;margin-top:36px;align-items:center">
        <a
          href="#contact"
          class="hover-primary"
          style="display:inline-flex;align-items:center;gap:9px;font-family:'Jost';font-size:16px;letter-spacing:.02em;background:#2743E8;color:#F4F2EC;border:none;border-radius:0;padding:15px 32px"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#F4F2EC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16v14H4z"></path><path d="M4 6l8 6 8-6"></path></svg>Get in touch
        </a>
        <a
          href="#work"
          class="hover-outline"
          style="display:inline-flex;align-items:center;gap:8px;font-family:'Jost';font-size:16px;letter-spacing:.02em;background:transparent;color:#2743E8;border:1px solid rgba(39,67,232,.5);border-radius:0;padding:14px 28px"
          >See my work →</a
        >
      </div>

      <div
        style="position:absolute;left:0;right:0;bottom:0;height:231px;background:linear-gradient(90deg,#C9CF9F,#E7E0A2,#F3EACB,#F4CBAA,#EFB4C1,#BCC6EC);-webkit-mask:linear-gradient(180deg,transparent,#000 78%);mask:linear-gradient(180deg,transparent,#000 78%)"
      >
      </div>
      <div
        class="scroll-cue"
        style="position:absolute;bottom:30px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:9px;animation:drift 2.8s ease-in-out infinite"
      >
        <span
          style="font-family:'Jost';font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:#3A3830"
          >scroll</span
        >
        <svg width="16" height="26" viewBox="0 0 16 26" fill="none">
          <path
            d="M8 1v22M2 17l6 6 6-6"
            stroke="#3A3830"
            stroke-width="1.3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </section>

    <!-- ══════════════ 2 · ABOUT ME (cement) ══════════════ -->
    <section
      id="about"
      data-screen-label="About"
      style="position:relative;background:#E9E5DC;padding:120px 0;scroll-margin-top:84px"
    >
      <div
        class="about-grid"
        style="max-width:1000px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:340px 1fr;gap:64px;align-items:stretch"
      >
        <div
          data-reveal="left"
          style="opacity:0;transform:translateY(24px);clip-path:inset(0 100% 0 0);transition:clip-path 1s cubic-bezier(.22,1,.36,1),opacity .9s ease,transform 1s cubic-bezier(.22,1,.36,1);background:#FBFAF7;box-shadow:0 16px 40px rgba(40,40,60,.14);display:flex;align-items:center;justify-content:center;padding:24px;width:100%;max-width:340px"
        >
          <div
            style="width:100%;aspect-ratio:5/6;overflow:hidden;position:relative;background:#F1EEE6;border:1px dashed rgba(39,67,232,.45);display:flex;align-items:center;justify-content:center"
          >
            <span
              style="font-family:'Jost';font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:rgba(39,67,232,.5)"
              >portrait</span
            >
          </div>
        </div>
        <div
          data-reveal="up"
          style="opacity:0;transform:translateY(22px);transition:opacity .95s ease,transform 1s cubic-bezier(.22,1,.36,1)"
        >
          <div
            style="font-family:'Jost';font-size:12px;letter-spacing:.32em;text-transform:uppercase;color:#2743E8;font-weight:500;margin-bottom:16px"
          >
            About me
          </div>
          <h2
            style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(30px,3.6vw,46px);line-height:1.05;margin:0 0 22px;color:#2743E8"
          >
            Science, translated into <span style="font-style:italic;font-weight:300">momentum</span>
          </h2>
          <p
            style="font-family:'Jost';font-weight:400;font-size:18px;line-height:1.85;color:#3A3830;margin:0 0 18px;text-wrap:pretty"
          >
            I'm a microbial-genomics PhD turned venture builder. For a decade I've carried the rigor
            of the lab into the messier work of building and operating early-stage ventures —
            translating deep science into decisions people can actually act on.
          </p>
          <p
            style="font-family:'Jost';font-weight:400;font-size:18px;line-height:1.85;color:#3A3830;margin:0;text-wrap:pretty"
          >
            My path runs through India, Australia, Canada, and the US — from the research bench, to
            national-scale science operations, to leading a venture operating model end-to-end. I care
            about clarity, systems that hold, and helping founders move faster.
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════ 3 · BACKGROUND (institutions & teams) ══════════════ -->
    <section
      id="background"
      data-screen-label="Background"
      style="position:relative;padding:96px 40px;scroll-margin-top:84px;background-color:#E2DDD1"
    >
      <div style="text-align:center;max-width:820px;margin:0 auto 56px">
        <div
          data-reveal="up"
          style="opacity:0;transform:translateY(20px);transition:opacity .9s ease,transform .9s cubic-bezier(.22,1,.36,1);font-family:'Jost';font-size:12px;letter-spacing:.32em;text-transform:uppercase;color:#2743E8;font-weight:500;margin-bottom:16px"
        >
          Where I've built
        </div>
        <h2
          data-reveal="up"
          style="opacity:0;transform:translateY(20px);transition:opacity .95s ease .06s,transform .95s cubic-bezier(.22,1,.36,1) .06s;font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(32px,4.6vw,56px);line-height:1.02;margin:0;color:#2743E8"
        >
          A decade across labs, universities <span style="font-style:italic;font-weight:300">&amp; venture programs</span>
        </h2>
      </div>
      <div
        class="bg-grid"
        data-reveal="up"
        style="opacity:0;transform:translateY(22px);transition:opacity 1s ease,transform 1s cubic-bezier(.22,1,.36,1);max-width:1080px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:0"
      >
        <div class="bg-cell bg-cell--r" style="padding:34px 24px;text-align:center;background-color:#F0EBDF">
          <div style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:27px;line-height:1.1;color:#23211C">Creative Destruction Lab</div>
          <div style="font-family:'Jost';font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#2743E8;margin-top:10px">SEATTLE, USA</div>
          <div style="font-family:'Jost';font-size:12.5px;line-height:1.5;color:#7A756A;margin-top:6px">Foster School of Business<br />University of Washington</div>
        </div>
        <div class="bg-cell bg-cell--r" style="padding:34px 24px;text-align:center;background-color:#F0EBDF">
          <div style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:27px;line-height:1.1;color:#23211C">Creative Destruction Lab</div>
          <div style="font-family:'Jost';font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#2743E8;margin-top:10px">VANCOUVER, CANADA</div>
          <div style="font-family:'Jost';font-size:12.5px;line-height:1.5;color:#7A756A;margin-top:6px">Sauder School of Business<br />University of British Columbia</div>
        </div>
        <div class="bg-cell bg-cell--r" style="padding:34px 24px;text-align:center;background-color:#F0EBDF">
          <div style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:27px;line-height:1.1;color:#23211C">Complete <br />Genomics</div>
          <div style="font-family:'Jost';font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#2743E8;margin-top:10px">VANCOUVER, CANADA</div>
          <div style="font-family:'Jost';font-size:12.5px;line-height:1.5;color:#7A756A;margin-top:6px">Field Application Scientist</div>
        </div>
        <div class="bg-cell" style="padding:34px 24px;text-align:center;background-color:#F0EBDF">
          <div style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:27px;line-height:1.1;color:#23211C">University of Western Australia</div>
          <div style="font-family:'Jost';font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#2743E8;margin-top:10px">PERTH, AUSTRALIA</div>
          <div style="font-family:'Jost';font-size:12.5px;line-height:1.5;color:#7A756A;margin-top:6px">Research Associate</div>
        </div>
        <div class="bg-cell bg-cell--r bg-cell--t" style="padding:34px 24px;text-align:center;background-color:#F0EBDF">
          <div style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:27px;line-height:1.1;color:#23211C">University of Queensland</div>
          <div style="font-family:'Jost';font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#2743E8;margin-top:10px">BRISBANE, AUSTRALIA</div>
          <div style="font-family:'Jost';font-size:12.5px;line-height:1.5;color:#7A756A;margin-top:6px">PhD · Microbial Genomics</div>
        </div>
        <div class="bg-gradient" style="grid-column:span 3;background:linear-gradient(90deg,#C9C6EC,#D3BCFB8E)"></div>
      </div>
    </section>

    <!-- ══════════════ 4 · WHAT I BRING (toolkit) ══════════════ -->
    <section
      id="toolkit"
      data-screen-label="Skills"
      style="position:relative;background:#E9E5DC;scroll-margin-top:84px"
    >
      <div style="max-width:1000px;margin:0 auto;padding:110px 40px 70px">
        <div style="text-align:center;margin-bottom:44px">
          <div
            data-reveal="up"
            style="opacity:0;transform:translateY(20px);transition:opacity .9s ease,transform .9s cubic-bezier(.22,1,.36,1);font-family:'Jost';font-size:12px;letter-spacing:.32em;text-transform:uppercase;color:#2743E8;font-weight:500;margin-bottom:16px"
          >
            The toolkit
          </div>
          <h2
            data-reveal="up"
            style="opacity:0;transform:translateY(20px);transition:opacity .95s ease .06s,transform .95s cubic-bezier(.22,1,.36,1) .06s;font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(34px,4.8vw,56px);line-height:1.02;margin:0;color:#2743E8"
          >
            What I bring
          </h2>
        </div>
        <div
          class="toolkit-grid"
          style="display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:rgba(39,67,232,.14);align-items:stretch"
        >
          <div
            data-reveal="left"
            style="opacity:0;clip-path:inset(0 100% 0 0);transition:clip-path 1s cubic-bezier(.22,1,.36,1),opacity .9s ease;background:#F1EEE6;border-top:4px solid #BCC6EC;padding:32px 30px 26px"
          >
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:26px;line-height:1;margin:0 0 4px;color:#23211C">Technical</h3>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1);margin-top:14px"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#8E9BD6"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Molecular biology &amp; genomics research</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#8E9BD6"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">AI-assisted development (software/app development, API integrations)</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#8E9BD6"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Workflow automations</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#8E9BD6"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Salesforce</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#8E9BD6"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Airtable</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#8E9BD6"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">MS Office Suite</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#8E9BD6"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">G Suite</span></div>
          </div>
          <div
            data-reveal="up"
            style="opacity:0;transform:translateY(26px);clip-path:inset(0 0 100% 0);transition:clip-path 1.05s cubic-bezier(.22,1,.36,1) .08s,opacity .95s ease .08s,transform 1s ease .08s;border-top:4px solid #F4CBAA;padding:32px 30px 26px;background-color:#F1EEE6"
          >
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:26px;line-height:1;margin:0 0 4px;color:#23211C">Transferable</h3>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1);margin-top:14px"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#E1954F"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Business development and partnerships</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#E1954F"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Program design and operations</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#E1954F"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Cross-industry evaluation</span></div>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1)"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#E1954F"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Founder advising and deal-flow screening</span></div>
          </div>
          <div
            data-reveal="right"
            style="opacity:0;clip-path:inset(0 0 0 100%);transition:clip-path 1s cubic-bezier(.22,1,.36,1) .16s,opacity .9s ease .16s;background:#F1EEE6;border-top:4px solid #C9CF9F;padding:32px 30px 26px"
          >
            <h3 style="font-family:'Cormorant Garamond',serif;font-weight:500;font-size:26px;line-height:1;margin:0 0 4px;color:#23211C">Soft</h3>
            <div style="display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-top:1px solid rgba(39,67,232,.1);margin-top:14px"><span style="flex:none;width:7px;height:7px;margin-top:6px;background:#97A46B"></span><span style="font-family:'Jost';font-size:14.5px;line-height:1.5;color:#3A3830">Translating technical work into business requirements</span></div>
