<style>
  /* Button hover states (the source design expressed these as style-hover attrs). */
  .hover-primary {
    transition: background 0.25s;
  }
  .hover-primary:hover {
    background: #1a2fb0 !important;
  }
  .hover-outline {
    transition: background 0.25s, border-color 0.25s;
  }
  .hover-outline:hover {
    background: rgba(39, 67, 232, 0.08) !important;
    border-color: #2743e8 !important;
  }

  /* Institution-grid dividers (the source expressed these as style-after/before attrs). */
  .bg-cell {
    position: relative;
  }
  .bg-cell--r::after {
    content: '';
    position: absolute;
    z-index: 2;
    top: -14px;
    bottom: -14px;
    right: -1px;
    width: 2px;
    background: linear-gradient(180deg, transparent, #6e63b8 14%, #6e63b8 86%, transparent);
  }
  .bg-cell--t::before {
    content: '';
    position: absolute;
    z-index: 2;
    left: -14px;
    right: -14px;
    top: -1px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #6e63b8 14%, #6e63b8 86%, transparent);
  }
</style>

<script>
  // ---------------------------------------------------------------------------
  // Reveal-on-scroll + runtime email assembly + hero parallax.
  // Vanilla port of the source design's DCLogic component.
  // ---------------------------------------------------------------------------
  const reveal = (el: HTMLElement) => {
    el.style.clipPath = 'inset(0 0 0 0)';
    el.style.opacity = '1';
    el.style.transform = 'none';
  };

  const reveals = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            reveal(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
    );
    reveals.forEach((el) => io.observe(el));

    // Sweep for anything already in view — on load and on every scroll, so no
    // element can get stuck invisible if the observer misses it.
    const sweep = () =>
      reveals.forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) {
          reveal(el);
          io.unobserve(el);
        }
      });
    setTimeout(sweep, 400);
    window.addEventListener('scroll', sweep, { passive: true });
  } else {
    reveals.forEach(reveal);
  }

  // ---- assemble the (bot-obfuscated) contact email at runtime ----
  const emailEl = document.getElementById('contact-email') as HTMLAnchorElement | null;
  if (emailEl) {
    const { a, b, c } = emailEl.dataset;
    if (a && b && c) {
      const addr = `${a}@${b}.${c}`;
      emailEl.href = `mailto:${addr}`;
      emailEl.textContent = addr;
    }
  }

  // ---- hero decor parallax ----
  const spark = document.getElementById('spark');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (spark && !prefersReduced) {
    window.addEventListener(
      'pointermove',
      (ev) => {
        const cx = ev.clientX / window.innerWidth - 0.5;
        const cy = ev.clientY / window.innerHeight - 0.5;
        spark.style.transform = `translate3d(${(cx * 40).toFixed(1)}px,${(cy * 34).toFixed(1)}px,0)`;
      },
      { passive: true }
    );
  }
</script>
