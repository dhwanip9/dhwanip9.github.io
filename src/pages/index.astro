              <line x1="106" y1="124" x2="106" y2="100"></line>
              <circle cx="106" cy="92" r="7"></circle>
              <rect x="160" y="176" width="22" height="80"></rect>
              <rect x="186" y="150" width="24" height="106"></rect>
              <line x1="198" y1="150" x2="198" y2="132"></line>
              <rect x="214" y="188" width="20" height="68"></rect>
