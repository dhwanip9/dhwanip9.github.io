                stroke-width="1.7"></path>
              <path d="M30 284 Q220 268 410 284" stroke-width="1.6"></path>
            </svg>

            <!-- 4 · Vancouver — Science World dome -->
            <svg
              data-scene="3"
              data-illo
              viewBox="0 0 440 320"
              style="position:absolute;inset:0;width:100%;height:100%;opacity:0;transition:opacity .7s ease"
              fill="none"
              stroke="#2743E8"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="30" y1="262" x2="410" y2="262"></line>
              <rect x="70" y="176" width="24" height="86"></rect>
              <rect x="100" y="150" width="26" height="112"></rect>
              <rect x="132" y="192" width="22" height="70"></rect>
              <rect x="160" y="164" width="24" height="98"></rect>
              <line x1="172" y1="164" x2="172" y2="146"></line>
              <rect x="192" y="184" width="22" height="78"></rect>
